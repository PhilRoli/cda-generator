APP_PORT=48718
APP_ADMIN_TOKEN=change-me
# Password that gates the unwatermarked (clean) PDF conversion at POST /api/pdf/upload.
# Leave empty to disable the endpoint entirely (fail-closed).
APP_CLEAN_PDF_PASSWORD=mbi24
APP_WATERMARK_TEXT=ÜBUNGSDOKUMENT
APP_WATERMARK_OPACITY=0.17

# PDF generation bounds (DoS protection). Converter is strictly serial — keep max-concurrent at 1.
APP_PDF_MAX_CONCURRENT=1
APP_PDF_ACQUIRE_TIMEOUT_SECONDS=5
APP_PDF_CONVERSION_TIMEOUT_SECONDS=60
APP_PDF_MAX_XML_BYTES=5242880
APP_PDF_MAX_FILE_SIZE=5MB
APP_PDF_MAX_REQUEST_SIZE=5MB
